# --- App ---
PORT=3000
NODE_ENV=development
COOKIE_SECRET=cambia-esto-en-produccion
FRONTEND_ORIGIN=http://localhost:5173
# URL pública del front (enlaces en correos de reset)
APP_PUBLIC_URL=http://localhost:5173

# Admin (bitácora): usuarios separados por coma (minúsculas). Alternativa: role=admin en Neo4j User.
ADMIN_USERNAMES=

# distributed = Cassandra + Neo4j + Redis + JWT | json = archivo local (sin Docker de BD)
# Si omites AUTH_STORE y defines CASSANDRA_CONTACT_POINTS, se usa distributed.
AUTH_STORE=


# JWT (obligatorio en modo distributed)
JWT_SECRET=supersecreto
JWT_EXPIRES_IN=1h
REMEMBER_ME_EXPIRES_IN=7d

# Cassandra (Docker: cassandra-node1; local: localhost)
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_DATACENTER=datacenter1
CASSANDRA_KEYSPACE=tec_digitalito
# En un solo nodo local usa 1; con Docker (3 nodos Cassandra) usa 3.
CASSANDRA_REPLICATION_FACTOR=1

# Redis: cluster (3 nodos) o una sola instancia
# REDIS_MODE=cluster | standalone (vacío = cluster si hay 3+ nodos en REDIS_NODES)
# En `docker compose`, el servicio backend sobrescribe REDIS_NODES con redis-node1:7000,... (red Docker).
REDIS_MODE=
REDIS_NODES=localhost:7000,localhost:7001,localhost:7002

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/tec_digitalito?retryWrites=true&w=majority

# Neo4j AuraDB
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@localhost

# Opcional: URL completa de transporte (tiene prioridad sobre SMTP_HOST)
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# Bloqueo por intentos fallidos (minutos; por defecto 30 según HU3)
LOCKOUT_MINUTES=30

# Frontend (Vite — solo en build/dev del cliente). Con API en Docker (compose) suele ser http://localhost:3001
VITE_API_URL=http://localhost:3000
